  "terms_intro_title": "Introduction",
  "terms_intro_content": "Welcome to Squad app. By using this app, you agree to comply with these terms and conditions. Please read them carefully before using the app.\n\nSquad is a social networking platform dedicated to football players, scouts, and coaches. We strive to provide a safe and professional environment for all users.",
  "terms_account_title": "Your Account",
  "terms_account_content": "• You must be at least 13 years old to use the app\n• You are responsible for maintaining the confidentiality of your account information\n• You must provide accurate and truthful information when registering\n• You may not share your account with others\n• We reserve the right to suspend or terminate your account if you violate these terms",
  "terms_content_title": "Content and Behavior",
  "terms_content_content": "You are responsible for all content you post. The following is prohibited:\n\n• Posting offensive, violent, or discriminatory content\n• Harassing or threatening other users\n• Posting false or misleading information\n• Impersonating others\n• Posting content that infringes intellectual property rights\n• Using the app for illegal purposes\n• Sending spam messages",
  "terms_privacy_title": "Privacy",
  "terms_privacy_content": "We respect your privacy and are committed to protecting your personal data. Please review our Privacy Policy to learn how we collect, use, and protect your information.\n\nWe collect data necessary to operate the app and improve your experience. We will not share your data with third parties without your consent.",
  "terms_ip_title": "Intellectual Property Rights",
  "terms_ip_content": "All intellectual property rights of the app, including design, logos, and content, are reserved to us.\n\nContent you post remains your property, but you grant us a non-exclusive license to use and display it in the app.",
  "terms_termination_title": "Account Termination",
  "terms_termination_content": "You can delete your account at any time from the app settings. When you delete your account:\n\n• All your personal data will be deleted\n• All your posts and comments will be deleted\n• You will not be able to recover your account after deletion",
  "terms_changes_title": "Changes to Terms",
  "terms_changes_content": "We reserve the right to modify these terms at any time. You will be notified of any material changes. Your continued use of the app after changes means you accept them.",
  "terms_contact_title": "Contact Us",
  "terms_contact_content": "If you have any questions about these terms, you can contact us at:\n\nEmail: support@squad-app.com",
  "last_updated": "Last updated: December 2024",
  "scroll_to_accept": "Scroll down to read all terms",

  "privacy_intro_title": "Introduction",
  "privacy_intro_content": "At Squad, we respect your privacy and are committed to protecting your personal data. This policy explains how we collect, use, and protect your information.",
  "privacy_data_collected_title": "Data We Collect",
  "privacy_data_collected_content": "• Account information (name, email, password)\n• Profile information (photo, country, position)\n• Content you post (posts, comments, photos, videos)\n• Usage data (your interactions with the app)\n• Device information (device type, operating system)",
  "privacy_data_use_title": "How We Use Your Data",
  "privacy_data_use_content": "• Providing and improving app services\n• Personalizing your experience\n• Communicating with you about your account\n• Ensuring app security\n• Analyzing app usage for improvements",
  "privacy_data_sharing_title": "Data Sharing",
  "privacy_data_sharing_content": "We do not sell your personal data. We may share your data only:\n• With your explicit consent\n• To comply with laws\n• To protect our rights and user safety",
  "privacy_data_security_title": "Data Security",
  "privacy_data_security_content": "We use advanced security technologies to protect your data, including encryption and secure servers.",
  "privacy_data_retention_title": "Data Retention",
  "privacy_data_retention_content": "We retain your data as long as your account is active. When you delete your account, your data will be deleted within 30 days.",
  "privacy_user_rights_title": "Your Rights",
  "privacy_user_rights_content": "You have the right to:\n• Access your data\n• Correct your data\n• Delete your account and data\n• Object to data processing",
  "privacy_children_title": "Children's Privacy",
  "privacy_children_content": "The app is not intended for children under 13. We do not knowingly collect data from children.",
  "privacy_cookies_title": "Cookies",
  "privacy_cookies_content": "We use cookies to improve your experience and remember your preferences.",
  "privacy_changes_title": "Policy Changes",
  "privacy_changes_content": "We may update this policy from time to time. We will notify you of any material changes.",
  "privacy_contact_title": "Contact Us",
  "privacy_contact_content": "For any privacy inquiries:\nEmail: privacy@squad-app.com",
  "privacy_last_updated": "Last updated: December 2025",

