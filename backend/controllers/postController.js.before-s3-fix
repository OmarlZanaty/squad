const db = require('../db');

exports.createPost = async (req, res) => {
    const { caption } = req.body || {};
    const userId = req.user.id; // We get this from the JWT middleware

    // Check if at least caption or media is provided
    if (!caption && !req.file) {
        return res.status(400).json({ message: 'Post must have either text or media.' });
    }

    // Construct the URL to access the file (if media exists)
    let mediaUrl = null;
    let mediaType = null;
    
    if (req.file) {
        mediaUrl = `/uploads/posts/media/${req.file.filename}`;
        mediaType = req.file.mimetype.startsWith('image') ? 'image' : 'video';
    }

    try {
        const sql = "INSERT INTO posts (user_id, media_type, media_url, caption) VALUES (?, ?, ?, ?)";
        await db.query(sql, [userId, mediaType, mediaUrl, caption || '']);

        res.status(201).json({ 
            message: 'Post created successfully.', 
            mediaUrl: mediaUrl,
            caption: caption || ''
        });
    } catch (error) {
        console.error("Post Creation Error:", error);
        res.status(500).json({ message: 'Server error while creating post.' });
    }
};
