exports.getPosts = async (req, res) => {
    // Pagination
    const page = parseInt(req.query.page, 10) || 1;
    const limit = 10;
    const offset = (page - 1) * limit;

    // Filters
    const { country, position } = req.query;
    
    // Get user ID from token (if authenticated)
    const userId = req.user ? req.user.id : null;

    try {
        let sql = `
            SELECT
                p.id, p.user_id, p.media_type, p.media_url, p.caption, p.created_at,
                u.name as author_name, u.profile_photo_url as author_photo, u.country, u.position,
                u.type as author_type,
                COALESCE(SUM(CASE WHEN r.reaction_type = 'like' THEN 1 ELSE 0 END), 0) as like_count,
                COALESCE(SUM(CASE WHEN r.reaction_type = 'love' THEN 1 ELSE 0 END), 0) as love_count,
                COALESCE(SUM(CASE WHEN r.reaction_type = 'talent' THEN 1 ELSE 0 END), 0) as talent_count,
                COALESCE(SUM(CASE WHEN r.reaction_type = 'amazing' THEN 1 ELSE 0 END), 0) as amazing_count,
                (SELECT COUNT(*) FROM comments WHERE post_id = p.id) as comment_count,
                MAX(CASE WHEN r.user_id = ? THEN r.reaction_type ELSE NULL END) as user_reaction
            FROM posts p
            JOIN users u ON p.user_id = u.id
            LEFT JOIN reactions r ON p.id = r.post_id
            WHERE 1=1
        `;

        const params = [userId || 0];

        if (country) {
            sql += ` AND u.country = ?`;
            params.push(country);
        }

        if (position) {
            sql += ` AND u.position = ?`;
            params.push(position);
        }

        sql += ` GROUP BY p.id, p.user_id, p.media_type, p.media_url, p.caption, p.created_at,
                 u.name, u.profile_photo_url, u.country, u.position, u.type
                 ORDER BY p.created_at DESC LIMIT ? OFFSET ?`;
        params.push(limit, offset);

        const [posts] = await db.query(sql, params);

        res.status(200).json(posts);

    } catch (error) {
        console.error("Get Posts Error:", error);
        res.status(500).json({ message: 'Server error while fetching posts.' });
    }
};
